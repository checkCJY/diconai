# drf-server (Django) 환경변수 템플릿
# 사용: cp .env.example .env  →  값 채워서 git에 커밋 안 함

# ── Django Core ────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-changeme-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# 로깅 레벨: DEBUG / INFO / WARNING / ERROR (운영은 INFO 이상 권장)
DJANGO_LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────
# 미설정 시 sqlite (db.sqlite3)로 폴백.
# 운영: postgres://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL=postgres://diconai:diconai@localhost:5432/diconai

# ── Redis & Celery ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT 토큰 수명 ──────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_HOURS=24
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ── 어드민 백오피스 진입 URL ─────────────────────────────────
ADMIN_BACKOFFICE_URL=/admin-panel/accounts-management/

# ── 서버 간 호출 (Celery → FastAPI WS 브리지) ───────────────
FASTAPI_INTERNAL_URL=http://127.0.0.1:8001

# ── 프론트엔드 노출용 URL (브라우저에서 접속) ────────────────
# FRONTEND_API_BASE_URL: 빈 문자열 = same-origin (Django 호스트)
# 운영 환경에서 fastapi가 다른 도메인이면 https://api.example.com 등으로 지정.
FRONTEND_API_BASE_URL=
FRONTEND_WS_BASE_URL=ws://127.0.0.1:8001
