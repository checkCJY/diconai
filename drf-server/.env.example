# drf-server (Django) 환경변수 템플릿
#
# [로컬 개발]
#   cp .env.example .env.dev  →  값 채우기
#   DJANGO_SETTINGS_MODULE=config.settings.dev  (manage.py 기본값이라 별도 설정 불필요)
#
# [운영/Docker]
#   환경변수는 ../.env.docker 에서 주입 (docker-compose env_file)
#   DJANGO_SETTINGS_MODULE=config.settings.prod  (docker-compose에서 자동 설정)
#
# [주의] DEBUG는 여기서 설정하지 않는다.
#   dev.py → DEBUG=True 고정 / prod.py → DEBUG=False 고정
#   환경변수로 바꿔도 prod 환경에서는 무시됨

# ── Django Core ────────────────────────────────────────────
# 값 생성: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=django-insecure-changeme-use-a-long-random-string
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────
# 미설정 시 SQLite(db.sqlite3)로 폴백 — 로컬 개발용
# PostgreSQL 사용 시 아래 주석 해제
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=diconai
# POSTGRES_USER=diconai
# POSTGRES_PASSWORD=diconai

# ── Redis & Celery ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT 토큰 수명 ──────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_HOURS=24
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ── 옵트인 보안 ────────────────────────────────────────────
# 미설정(빈 문자열) = 비활성. 운영에서는 반드시 설정.
# 값 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
# INTERNAL_SERVICE_TOKEN=
# JWT_SIGNING_KEY=

# ── 서버 간 호출 ────────────────────────────────────────────
FASTAPI_INTERNAL_URL=http://127.0.0.1:8001
FRONTEND_API_BASE_URL=
FRONTEND_WS_BASE_URL=ws://127.0.0.1:8001

# ── Discord 알람 연동 ───────────────────────────────────────
# 알람을 외부 Discord 채널로도 발송. 미설정(False/빈 값)이면 미발송.
# webhook URL: Discord 채널 설정 → 연동 → 웹훅 → 새 웹훅 → URL 복사
DISCORD_ALARM_ENABLED=False
DISCORD_WEBHOOK_ADMIN=
DISCORD_WEBHOOK_WORKER=

# ── 어드민 백오피스 ─────────────────────────────────────────
ADMIN_BACKOFFICE_URL=/admin-panel/accounts-management/

# ── 시연용 알람 재팝업 쿨다운 (초) ─────────────────────────
# 운영: 60, 시연: 15
ALARM_REPOPUP_COOLDOWN_SEC=15
