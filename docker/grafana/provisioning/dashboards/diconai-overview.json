      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "id": 6,
      "title": "DRF — 에러율 5xx (5m)",
      "description": "전체 요청 중 500번대 응답 비율. 0에 가까워야 정상. 올라가면 Django 서버 내부 오류 발생 중 — AppLog(시스템 로그)와 함께 확인한다.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"drf\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"drf\"}[5m]))",
          "legendFormat": "에러율",
          "refId": "A"
        }
      ]
