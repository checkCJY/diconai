  "panels": [

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "title": "DRF — 요청 수 (RPS, 5m)",
      "description": "Django 서버로 들어오는 초당 요청 수. 경로별로 분리해 어느 API가 가장 많이 호출되는지 확인한다. 급격히 떨어지면 서버 다운 또는 네트워크 이상.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (path) (rate(http_requests_total{job=\"drf\"}[5m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "title": "DRF — 응답시간 p95 (5m)",
      "description": "상위 5% 느린 요청의 응답시간. 평균보다 실제 사용자가 체감하는 속도에 가깝다. 이 값이 올라가면 특정 API에 병목이 생긴 것.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"drf\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 6,
      "title": "DRF — 에러율 5xx (5m)",
      "description": "전체 요청 중 500번대 응답 비율. 0에 가까워야 정상. 올라가면 Django 서버 내부 오류 발생 중 — AppLog(시스템 로그)와 함께 확인한다.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"drf\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"drf\"}[5m]))",
          "legendFormat": "에러율",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 3,
      "title": "FastAPI — 요청 수 (RPS, 5m)",
      "description": "FastAPI 서버로 들어오는 초당 요청 수. 센서 데이터 수신(/api/sensors/gas, /api/power/*), WebSocket, 내부 알람 푸시 등이 포함된다.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (path) (rate(http_requests_total{job=\"fastapi\"}[5m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 4,
      "title": "FastAPI — 응답시간 p95 (5m)",
      "description": "FastAPI 응답시간 p95. 센서 ingest는 1초 간격으로 들어오므로 여기가 느려지면 데이터 수신 지연으로 이어진다.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"fastapi\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 7,
      "title": "FastAPI — 에러율 5xx (5m)",
      "description": "FastAPI 500번대 응답 비율. 올라가면 센서 데이터 처리 실패 or DRF 저장 실패 가능성 — IntegrationLog(연동 로그)와 함께 확인한다.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"fastapi\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"fastapi\"}[5m]))",
          "legendFormat": "에러율",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "id": 8,
      "title": "센서 데이터 ingest 건수 (가스, 5m)",
      "description": "FastAPI가 수신하는 가스 센서 데이터 초당 건수. 센서 1개가 1초 간격으로 전송하므로 센서 수와 비례해야 한다. 뚝 떨어지면 센서 연결 끊김 또는 FastAPI 수신 장애.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"fastapi\", path=\"/api/sensors/gas\", method=\"POST\"}[5m])",
          "legendFormat": "가스 ingest",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "id": 9,
      "title": "DRF vs FastAPI — 응답시간 비교 p95 (5m)",
      "description": "두 서버의 p95 응답시간을 같은 그래프에 표시. Django가 느린지 FastAPI가 느린지 한눈에 구분 — 병목 서버 특정에 사용한다.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 32},
      "id": 5,
      "title": "서비스 가동 상태 (1=정상, 0=중단)",
      "description": "Prometheus가 각 서버의 /metrics 수집에 성공하면 1, 실패하면 0. DRF/FastAPI 둘 다 1이어야 정상 운영 상태.",
      "type": "stat",
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "thresholds": {
          "steps": [
            {"color": "red", "value": 0},
            {"color": "green", "value": 1}
          ]
        }
      },
      "targets": [
        {"expr": "up", "legendFormat": "{{job}}", "refId": "A"}
      ]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "cps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
      "id": 10,
      "title": "Celery — 알람 발송 횟수 (5m)",
      "description": "Celery worker가 실제로 WebSocket에 푸시한 알람 초당 건수. dedupe·쿨다운을 통과한 것만 카운팅. 이 값이 비정상적으로 높으면 알람 폭주 — alarm_type/risk_level 라벨로 어떤 알람인지 확인한다.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (alarm_type, risk_level) (rate(alarm_fired_total[5m]))",
          "legendFormat": "{{alarm_type}} / {{risk_level}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "cps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
      "id": 11,
      "title": "Celery — WS 푸시 실패 횟수 (5m)",
      "description": "FastAPI /internal/alarms/push/ 호출 실패 횟수. 이 값이 올라가면 알람이 브라우저에 전달되지 않은 것 — FastAPI 에러율 패널과 함께 확인한다.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (alarm_type) (rate(alarm_ws_push_failed_total[5m]))",
          "legendFormat": "{{alarm_type}}",
          "refId": "A"
        }
      ]
    }

  ],
