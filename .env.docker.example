# ============================================================
# diconai — Docker Compose 통합 환경변수
# 사용: cp .env.docker.example .env.docker  →  값 채우기 (git ignored)
# 두 서버(drf, fastapi) + celery 모두 이 한 파일에서 주입받음.
# ============================================================

# ── Django Core ──────────────────────────────────────────────
# 값 생성: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=changeme-please-generate-a-strong-key
DJANGO_DEBUG=False
# 컨테이너 내부 호스트명 + 호스트에서 접속할 도메인
DJANGO_ALLOWED_HOSTS=drf,localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# ── 서비스 간 인증 (양 서버 동일 값 필수) ────────────────────
# 값 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# ⚠️ INTERNAL_SERVICE_TOKEN 과 DRF_SERVICE_TOKEN 은 반드시 같은 값으로!
#   - INTERNAL_SERVICE_TOKEN: drf 가 검증하는 값 (drf/fastapi 양쪽이 같이 가짐)
#   - DRF_SERVICE_TOKEN:      fastapi → drf 호출 시 헤더에 부착되는 값
#   - 다르게 채우면 fastapi 의 가스 더미가 모두 HTTP 502 (drf 가 401 Unauthorized 반환)
#     자세한 진단/해결: docs/infra/docker_setup.md §10 ⑥
INTERNAL_SERVICE_TOKEN=changeme-internal-token
DRF_SERVICE_TOKEN=changeme-internal-token

# WebSocket JWT 검증용 (drf SimpleJWT ↔ fastapi WS 가 공유). 위 토큰과는 별개 시크릿.
JWT_SIGNING_KEY=changeme-jwt-key
JWT_ALGORITHM=HS256
DRF_REQUEST_TIMEOUT_SEC=5.0

# ── JWT 토큰 수명 ────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_HOURS=2
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── 어드민 백오피스 ─────────────────────────────────────────
ADMIN_BACKOFFICE_URL=/admin-panel/accounts-management/

# ── 프론트엔드 노출 URL (브라우저가 host에서 접속) ──────────
# 빈 문자열이면 same-origin (Django 호스트와 같은 도메인)
FRONTEND_API_BASE_URL=
FRONTEND_WS_BASE_URL=ws://localhost:8001

# ── FastAPI 도메인 설정 ─────────────────────────────────────
LOG_LEVEL=INFO
BROADCAST_INTERVAL_SEC=5.0
DATA_STALE_THRESHOLD_SEC=8.0
POWER_THRESHOLD_CAUTION=2200
POWER_THRESHOLD_DANGER=2860

# ── 더미 송출 (필요시) ──────────────────────────────────────
DUMMY_TARGET_HOST=fastapi
DUMMY_TARGET_PORT=8001
DUMMY_SEND_INTERVAL_SEC=1.0
DUMMY_RISK_PROBABILITY=0.1

# ── 알림 지연 임계 ──────────────────────────────────────────
NOTIFICATION_DELAY_THRESHOLD_MINUTES=5

# ── Grafana 관리자 ──────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ============================================================
# 주의:
# - DATABASE_URL, REDIS_URL, FASTAPI_INTERNAL_URL, DRF_BASE_URL 은
#   docker-compose.yml의 environment 블록에서 서비스명 기반으로 직접 주입.
#   여기서는 설정하지 않음. (override가 필요하면 compose 파일을 수정)
# ============================================================
