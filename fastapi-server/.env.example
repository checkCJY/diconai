# fastapi-server 환경변수 템플릿
# 사용: cp .env.example .env  →  값 채워서 git에 커밋 안 함

# ── 로깅 ───────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR (운영은 INFO 이상 권장)
LOG_LEVEL=INFO

# ── Redis ──────────────────────────────────────────────────
# 알람 큐(diconai:ws:alarms) 등 공유 저장소.
# 로컬: redis://localhost:6379/0, 도커: compose가 redis://redis:6379/0 주입.
REDIS_URL=redis://localhost:6379/0

# ── DRF 연동 ───────────────────────────────────────────────
DRF_BASE_URL=http://localhost:8000
# fastapi → drf 호출 시 Authorization: Bearer <값> 헤더에 부착되는 값.
# 옵트인 활성화 시: 아래 INTERNAL_SERVICE_TOKEN과 동일 값으로 채울 것
#   (drf 측은 INTERNAL_SERVICE_TOKEN 한 값으로 들어오는 헤더를 검증).
# 빈 문자열이면 헤더 미부착 → 옵트인 켠 drf는 401 반환.
DRF_SERVICE_TOKEN=
DRF_REQUEST_TIMEOUT_SEC=5.0

# ── 옵트인 보안 (Phase 5, 2026_05_09 wave) ─────────────────
# 미설정(빈 문자열) = 비활성, 기존 무인증 동작 유지.
# 활성화 시 양 서버(.env) 동일 값 필수. 한쪽만 설정 시 인증 실패 → 통신 차단.
# 값 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 💡 단일 토큰 운영이면 아래 INTERNAL_SERVICE_TOKEN과 위의 DRF_SERVICE_TOKEN에
#    같은 값을 넣으세요. (변수가 두 개인 이유: 향후 클라이언트별로 다른 토큰을
#    쓸 수 있도록 인입(INTERNAL_SERVICE_TOKEN)/인출(DRF_SERVICE_TOKEN)을 분리.)
#
# Celery → fastapi alarm-push 인증용. drf-server와 동일 값.
# ⚠️ 위의 DRF_SERVICE_TOKEN(fastapi → drf 헤더용)과 별개 변수 — 둘 다 채워야 함.
# INTERNAL_SERVICE_TOKEN=
#
# WS 연결 JWT 검증용. drf-server의 JWT_SIGNING_KEY와 동일 값.
# JWT_SIGNING_KEY=
# JWT_ALGORITHM=HS256

# ── WebSocket 브로드캐스트 ─────────────────────────────────
BROADCAST_INTERVAL_SEC=5.0
DATA_STALE_THRESHOLD_SEC=8.0

# ── 전력 임계치 (단위: W, Phase A 기준) ──────────────────────
# DRF apps.core.constants.POWER_THRESHOLDS와 동일 값 유지 필요.
POWER_THRESHOLD_CAUTION=2200
POWER_THRESHOLD_DANGER=2860

# ── 더미 송출 (개발/테스트 전용) ─────────────────────────────
DUMMY_TARGET_HOST=127.0.0.1
DUMMY_TARGET_PORT=8001
DUMMY_SEND_INTERVAL_SEC=1.0
DUMMY_RISK_PROBABILITY=0.1
# 부팅 시 시나리오 초기 모드. mixed=확률 기반 / normal·warning·danger=고정.
# DUMMY_SCENARIO_MODE=mixed
# 더미 작업자가 속한 시설 ID (미설정 시 코드 기본값 1).
# DUMMY_FACILITY_ID=1

# ── 시연 시나리오 override (미설정 시 코드 기본값) ───────────
# 가스 co_leak 상태머신 틱 (기본 5/30/5).
# DEMO_CO_LEAK_RAMP_UP_TICKS=20
# DEMO_CO_LEAK_HOLD_TICKS=10
# DEMO_CO_LEAK_RAMP_DOWN_TICKS=5
# 가스 AI Change Point penalty (기본 3.0 — 낮추면 부드러운 ramp 도 감지).
# DEMO_GAS_CP_PENALTY=1.0
# 전력 overload 상태머신 틱 (기본 5/60/10).
# DEMO_OVERLOAD_RAMP_UP_TICKS=20
# DEMO_OVERLOAD_HOLD_TICKS=15
# DEMO_OVERLOAD_RAMP_DOWN_TICKS=5

# ── AI 알람 / ML 모델 (미설정 시 코드 기본값) ───────────────
# 같은 센서 AI 이상탐지 알람 최소 발화 간격(초).
# GAS_AI_RATE_LIMIT_SEC=30
# IF 모델 .pkl 디렉토리. 컨테이너: /app/ml_models.
# ML_MODELS_DIR=/app/ml_models
# 모델 캐시 TTL(초). 0 이하면 영구 캐시.
# ML_MODEL_CACHE_TTL_SEC=3600
# AI 이상탐지 결과를 DRF로 forward 할지(event_id 확보). 기본 on.
# FORWARD_ANOMALY_TO_DRF=true

# JWT_SIGNING_KEY 는 위 "옵트인 보안" 섹션에서 설정한다 (drf 와 동일 값).
# 템플릿에는 실제 키를 두지 않는다 — 실 비밀값은 .env 에만, git 추적 금지.
# JWT_SIGNING_KEY=
